# Wikipedia RAG Studio local demo settings.
# Copy this file to .env if you want to override defaults locally.

PORT=4055
QMD_WIKI_RAG_PROVIDER=ollama
QMD_WIKI_RAG_OLLAMA_MODEL=wiki-rag-answer-dpo
QMD_WIKI_RAG_OLLAMA_TIMEOUT_MS=45000
QMD_WIKI_RAG_MAX_TOKENS=220

# Optional if Ollama is not running on the default host.
# OLLAMA_HOST=http://127.0.0.1:11434
